# ─── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_USER=dsim
POSTGRES_PASSWORD=dsim_dev
POSTGRES_DB=dsim
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Async URL for SQLAlchemy + asyncpg (used by FastAPI runtime)
DATABASE_URL=postgresql+asyncpg://dsim:dsim_dev@localhost:5432/dsim
# Sync URL for Alembic migrations
DATABASE_SYNC_URL=postgresql+psycopg://dsim:dsim_dev@localhost:5432/dsim

# ─── Redis (queue + cache) ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── LLM providers (Step 2+) ────────────────────────────────────────────────
# Pick one or both — Step 2 will use whichever is set.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Web search grounding (Step 2) ──────────────────────────────────────────
# At least one is required for evidence-anchored ICP generation.
TAVILY_API_KEY=
EXA_API_KEY=

# ─── App config ─────────────────────────────────────────────────────────────
ENV=development              # development | staging | production
LOG_LEVEL=INFO
API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000

# ─── Feature flags (used in Steps 2–4) ──────────────────────────────────────
# Hard-fail if a pipeline runs without grounding evidence
REQUIRE_EVIDENCE_ANCHORS=true
# Min number of independent sources before a fact is "high confidence"
MIN_SOURCES_FOR_HIGH_CONFIDENCE=3
